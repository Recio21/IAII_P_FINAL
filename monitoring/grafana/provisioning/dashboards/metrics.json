{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana",    "id": "grafana",    "name": "Grafana",    "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "gauge",      "name": "Gauge",       "version": "" },
    { "type": "panel", "id": "stat",       "name": "Stat",        "version": "" },
    { "type": "panel", "id": "piechart",   "name": "Pie chart",   "version": "" },
    { "type": "panel", "id": "barchart",   "name": "Bar chart",   "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "PipelineModeling — MLOps runtime metrics (emotion classifier)",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["mlops", "emotions", "pipeline"],
  "timezone": "utc",
  "title": "PipelineModeling — MLOps",
  "uid": "pipelinemodeling-mlops-v1",
  "version": 2,
  "weekStart": "",
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},

  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Datasource",
        "multi": false,
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "type": "datasource"
      }
    ]
  },

  "panels": [

    {
      "id": 1,
      "title": "Predictions / sec",
      "description": "Inference requests served per second (1m rate)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 12, "spanNulls": true },
          "unit": "reqps",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(inference_predictions_total[1m]))",
          "legendFormat": "predictions/s",
          "refId": "A"
        }
      ]
    },

    {
      "id": 2,
      "title": "Inference Latency P95 (ms)",
      "description": "P50, P95 and P99 latency in milliseconds (preprocess + model forward pass)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 6, "spanNulls": true },
          "unit": "ms",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.50, sum(rate(inference_latency_seconds_bucket[2m])) by (le)) * 1000",
          "legendFormat": "P50", "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.95, sum(rate(inference_latency_seconds_bucket[2m])) by (le)) * 1000",
          "legendFormat": "P95", "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.99, sum(rate(inference_latency_seconds_bucket[2m])) by (le)) * 1000",
          "legendFormat": "P99", "refId": "C"
        }
      ]
    },

    {
      "id": 3,
      "title": "Error Rate by Endpoint",
      "description": "Error events per second grouped by endpoint and error kind",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10, "spanNulls": true },
          "unit": "short",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(inference_errors_total[2m])) by (endpoint, kind)",
          "legendFormat": "{{ endpoint }} / {{ kind }}", "refId": "A"
        }
      ]
    },

    {
      "id": 4,
      "title": "Active Model Version",
      "description": "Currently loaded model. Series name = version label.",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "dark-green" },
          "unit": "none",
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "dark-green", "value": null }]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "name",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "active_model_info == 1",
          "legendFormat": "{{ model_version }}", "refId": "A",
          "instant": true
        }
      ]
    },

    {
      "id": 5,
      "title": "Prediction Confidence — Avg & P10",
      "description": "Rolling average confidence and P10 (low = model is uncertain, possible drift). P10 below 0.5 sustained is a drift signal.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 8, "spanNulls": true },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "P10 confidence" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "dash": [6, 3], "fill": "dash" } },
              { "id": "color", "value": { "fixedColor": "#f5a623", "mode": "fixed" } }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(prediction_confidence_sum[2m]) / rate(prediction_confidence_count[2m])",
          "legendFormat": "avg confidence", "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.10, sum(rate(prediction_confidence_bucket[5m])) by (le))",
          "legendFormat": "P10 confidence", "refId": "B"
        }
      ]
    },

    {
      "id": 6,
      "title": "Top Emotions Predicted",
      "description": "Distribution of predicted emotion classes in selected time range",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 10, "x": 6, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "pieType": "donut",
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "table", "placement": "right", "values": ["percent", "value"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "topk(6, sum(increase(inference_predictions_total[$__range])) by (emotion))",
          "legendFormat": "{{ emotion }}", "refId": "A", "instant": true
        }
      ]
    },

    {
      "id": 7,
      "title": "Latency Percentile Distribution",
      "description": "P50 / P75 / P90 / P95 / P99 as bar chart — snapshot of current distribution",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 80, "lineWidth": 0 },
          "unit": "ms",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "xTickLabelRotation": 0,
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "barWidth": 0.7
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.50, sum(rate(inference_latency_seconds_bucket[5m])) by (le)) * 1000",
          "legendFormat": "P50", "refId": "A", "instant": true
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.75, sum(rate(inference_latency_seconds_bucket[5m])) by (le)) * 1000",
          "legendFormat": "P75", "refId": "B", "instant": true
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.90, sum(rate(inference_latency_seconds_bucket[5m])) by (le)) * 1000",
          "legendFormat": "P90", "refId": "C", "instant": true
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.95, sum(rate(inference_latency_seconds_bucket[5m])) by (le)) * 1000",
          "legendFormat": "P95", "refId": "D", "instant": true
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.99, sum(rate(inference_latency_seconds_bucket[5m])) by (le)) * 1000",
          "legendFormat": "P99", "refId": "E", "instant": true
        }
      ]
    },

    {
      "id": 8,
      "title": "Backend Health",
      "description": "1 = target UP and reachable by Prometheus. Drift score overlay.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 8, "spanNulls": true },
          "unit": "short",
          "min": 0,
          "max": 1
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "drift score" },
            "properties": [
              { "id": "unit", "value": "percentunit" },
              { "id": "custom.lineStyle", "value": { "dash": [8, 4], "fill": "dash" } },
              { "id": "color", "value": { "fixedColor": "#f5a623", "mode": "fixed" } }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "up{job=\"pipeline-backend\"}",
          "legendFormat": "backend UP", "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "drift_score",
          "legendFormat": "drift score", "refId": "B"
        }
      ]
    },

    {
      "id": 9,
      "title": "Observations & Seeder Activity",
      "description": "Cumulative observations stored and seeder request rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 8, "spanNulls": true },
          "unit": "short",
          "min": 0
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "observations (total)" },
            "properties": [
              { "id": "custom.axisPlacement", "value": "right" },
              { "id": "unit", "value": "short" }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(seeder_requests_total[1m]))",
          "legendFormat": "seeder req/s", "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "observations_total",
          "legendFormat": "observations (total)", "refId": "B"
        }
      ]
    }

  ]
}
