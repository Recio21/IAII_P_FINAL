{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "8.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "PipelineModeling — MLOps runtime metrics",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    {
      "id": 1,
      "title": "Predictions / sec",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum(rate(inference_predictions_total[1m]))",
          "legendFormat": "predictions/s",
          "refId": "A"
        }
      ]
    },

    {
      "id": 2,
      "title": "Inference Latency P50 / P95 / P99",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 5 },
          "unit": "s"
        },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(inference_latency_seconds_bucket[2m])) by (le))",
          "legendFormat": "P50", "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(inference_latency_seconds_bucket[2m])) by (le))",
          "legendFormat": "P95", "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(inference_latency_seconds_bucket[2m])) by (le))",
          "legendFormat": "P99", "refId": "C"
        }
      ]
    },

    {
      "id": 3,
      "title": "Error Rate by Endpoint",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "short"
        },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum(rate(inference_errors_total[2m])) by (endpoint)",
          "legendFormat": "{{ endpoint }}", "refId": "A"
        }
      ]
    },

    {
      "id": 4,
      "title": "Top Emotions Predicted",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" },
        "overrides": []
      },
      "options": {
        "pieType": "donut",
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "table", "placement": "right", "values": ["percent"] }
      },
      "targets": [
        {
          "expr": "sum(increase(inference_predictions_total[$__range])) by (emotion)",
          "legendFormat": "{{ emotion }}", "refId": "A"
        }
      ]
    },

    {
      "id": 5,
      "title": "Drift Score",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 4, "x": 8, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 1, "unit": "percentunit",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.4 },
              { "color": "red", "value": 0.7 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto" },
      "targets": [
        { "expr": "drift_score", "legendFormat": "drift", "refId": "A" }
      ]
    },

    {
      "id": 6,
      "title": "Observations Stored (total)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "blue", "value": null }] },
          "unit": "short", "mappings": []
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto", "graphMode": "area" },
      "targets": [
        { "expr": "observations_total", "legendFormat": "observations", "refId": "A" }
      ]
    },

    {
      "id": 7,
      "title": "Seeder Requests / sec",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          },
          "unit": "reqps", "mappings": []
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto", "graphMode": "area" },
      "targets": [
        {
          "expr": "sum(rate(seeder_requests_total[1m]))",
          "legendFormat": "seeder req/s", "refId": "A"
        }
      ]
    },

    {
      "id": 8,
      "title": "Model Load Time (last)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 15 }
            ]
          },
          "unit": "s", "mappings": []
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "valueAndName", "graphMode": "none" },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(model_load_seconds_bucket[10m])) by (le))",
          "legendFormat": "load P99", "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(model_switch_seconds_bucket[10m])) by (le))",
          "legendFormat": "switch P99", "refId": "B"
        }
      ]
    }

  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["mlops", "pipeline", "emotions"],
  "templating": { "list": [] },
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "PipelineModeling — MLOps",
  "uid": "pipelinemodeling-mlops-v1",
  "version": 1,
  "weekStart": ""
}
