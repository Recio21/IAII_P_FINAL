# ===== Backend =====
APP_NAME=PipelineModeling
APP_ENV=local
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000
MODEL_DIR=/app/models
ACTIVE_MODEL_FILE=model_7_final.keras
METADATA_FILE=metadata_7.json
OBSERVATIONS_PATH=/app/data/observations.jsonl
MAX_UPLOAD_BYTES=5242880
TF_CPP_MIN_LOG_LEVEL=2

# ===== Seeder =====
API_BASE_URL=http://backend:8000
SEEDER_RPS=5
SEEDER_CONCURRENCY=4
SEEDER_IMAGE_DIR=/app/sample_images
SEEDER_TIMEOUT=10
SEEDER_BACKOFF_INITIAL=1.0
SEEDER_BACKOFF_MAX=30.0

# ===== Grafana =====
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin


# ===== Git =====
GITHUB_TOKEN=